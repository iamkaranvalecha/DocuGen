<UserControl x:Class="DocuGen.Window.FilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DocuGen.Window"
             xmlns:platform="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             toolkit:Themes.UseVsTheme="True"
             mc:Ignorable="d"
             >
    <Grid>
        <StackPanel Margin="10">
            <Button x:Name="RefreshButton" Content="Refresh" Margin="0,0,0,5" />
            <Button x:Name="SettingsButton" Content="Settings" Margin="0,0,0,5" />
            <TreeView x:Name="FileTreeView" Height="300" Margin="0,0,0,5"/>
            <Button x:Name="GenerateDocumentationButton" Content="Generate Documentation" />
        </StackPanel>
    </Grid>
</UserControl>
